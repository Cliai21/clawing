# ═══════════════════════════════════════════════════════════════
# OpenClaw Miner CLI — Mainnet Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values before mining.
#
# ⚠️  SECURITY:
#   - NEVER commit .env to git (already in .gitignore)
#   - Use a dedicated mining wallet (NOT your main wallet)
#   - This wallet only needs ETH for gas fees (~0.005 ETH/mint)
#   - CLAW rewards are minted directly to this wallet address
# ═══════════════════════════════════════════════════════════════

# === Wallet ===
# Mining wallet private key (hex with 0x prefix)
# Only needs ~0.01 ETH for gas fees
PRIVATE_KEY=0x_YOUR_MINING_WALLET_KEY_HERE

# === AI API ===
# Any OpenAI-compatible API endpoint
# Supported: xAI (recommended), OpenRouter, etc.
AI_API_KEY=xai-YOUR_API_KEY_HERE
AI_API_URL=https://api.x.ai/v1/chat/completions
# Must match current Era model (Era 1 = grok-4.1-fast)
AI_MODEL=grok-4.1-fast

# === Oracle ===
# Oracle server endpoint (HTTPS in production)
ORACLE_URL=https://oracle.openclaw.io

# === Chain ===
# Ethereum Mainnet RPC
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# PoAIWMint contract address (fill after deployment)
POAIW_MINT_ADDRESS=0x_FILL_AFTER_DEPLOYMENT

# === Mining Config ===
# Maximum gas price in gwei — auto-waits if gas exceeds this
# Recommended: 2-5 gwei for cost efficiency
MAX_GAS_PRICE_GWEI=3

# Custom task prompt (optional — if not set, uses default)
# The prompt is sent to the AI model for each mining attempt
TASK_PROMPT=Explain the fundamentals of distributed consensus mechanisms in detail.
