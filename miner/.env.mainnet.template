# ═══════════════════════════════════════════════════════
#   Clawing Miner .env — Ethereum Mainnet
#   ⚠️ Fill in actual contract addresses after deployment, chmod 600 to protect
# ═══════════════════════════════════════════════════════

# Ethereum Mainnet RPC
RPC_URL=https://ethereum-rpc.publicnode.com
CHAIN_ID=1

# Contract address (fill in after deployment)
POAIW_MINT_ADDRESS=<fill in after deployment>

# Oracle URL (use localhost if on the same server)
# F-15: Default to production Oracle URL
ORACLE_URL=https://oracle.minewithclaw.com

# Miner private key ⚠️ Never expose!
PRIVATE_KEY=<your Deployer private key, starting with 0x>

# AI API configuration (xAI Direct)
AI_API_URL=https://api.x.ai/v1/chat/completions
AI_API_KEY=<your xAI API Key>
# F-14: Fixed model name (was grok-4-1-fast, correct is grok-4.1-fast)
AI_MODEL=grok-4.1-fast

# Gas protection (conservative settings recommended for mainnet)
MAX_GAS_PRICE_GWEI=30
