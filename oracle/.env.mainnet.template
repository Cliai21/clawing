# ═══════════════════════════════════════════════════════
#   Clawing Oracle .env — Ethereum Mainnet
#   ⚠️ Fill in actual contract addresses after deployment, chmod 600 to protect
# ═══════════════════════════════════════════════════════

# Ethereum Mainnet RPC (public node, can be replaced with Alchemy/Infura)
RPC_URL=https://ethereum-rpc.publicnode.com
CHAIN_ID=1

# Contract addresses (fill in after deployment)
POAIW_MINT_ADDRESS=<fill in after deployment>
ORACLE_VERIFIER_ADDRESS=<fill in after deployment>
CLAW_TOKEN_ADDRESS=<fill in after deployment>

# Oracle signing private key ⚠️ Never expose!
ORACLE_PRIVATE_KEY=<your Deployer private key, starting with 0x>

# Server port
PORT=3000

# Era 1 model
ERA1_MODEL=grok-4.1-fast

# Trusted Router Aliases (API-returned model name → on-chain canonical model name)
TRUSTED_ROUTER_ALIASES=x-ai/grok-4.1-fast:grok-4.1-fast,grok-4-1-fast:grok-4.1-fast,grok-4-1-fast-reasoning:grok-4.1-fast,grok-4-1-fast-non-reasoning:grok-4.1-fast
