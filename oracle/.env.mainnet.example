# ═══════════════════════════════════════════════════════════════
# OpenClaw Oracle Server — Mainnet Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values before starting.
# 
# ⚠️  SECURITY:
#   - NEVER commit .env to git (already in .gitignore)
#   - Use a dedicated Oracle signing key (NOT the deployer key)
#   - Store backups of this key in a separate secure location
# ═══════════════════════════════════════════════════════════════

# Oracle signing key (ECDSA private key, hex with 0x prefix)
# This key must correspond to an address registered in OracleVerifier
ORACLE_PRIVATE_KEY=0x_YOUR_ORACLE_SIGNING_KEY_HERE

# Ethereum Mainnet RPC URL (use Alchemy or Infura for reliability)
# Recommended: Alchemy Growth plan for production
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ═══ Contract Addresses (fill after mainnet deployment) ═══
POAIW_MINT_ADDRESS=0x_FILL_AFTER_DEPLOYMENT
ORACLE_VERIFIER_ADDRESS=0x_FILL_AFTER_DEPLOYMENT

# Server config
PORT=3000
CHAIN_ID=1

# ═══ Nonce Config ═══
# Nonce TTL: how long a nonce remains valid (seconds)
NONCE_TTL_SECONDS=300
# Max active nonces per miner address
NONCE_MAX_PER_ADDRESS=3

# ═══ Rate Limit ═══
# Aligned with on-chain cooldown (3500 blocks × ~12s = ~41,667s)
# Using 41,000s for slight margin
RATE_LIMIT_WINDOW_SECONDS=41000
RATE_LIMIT_MAX_PER_WINDOW=1

# ═══ Deadline Config ═══
# Blocks ahead for signature deadline (mainnet ~12s/block)
# 200 blocks = ~40 minutes — enough time for miner to submit tx
DEADLINE_BLOCKS_AHEAD=200
# Maximum acceptable deadline distance from current block
SIGNATURE_VALIDITY_BLOCKS=300

# ═══ Optional: Monitoring ═══
# Uncomment to enable Prometheus metrics at /metrics
# ENABLE_METRICS=true
